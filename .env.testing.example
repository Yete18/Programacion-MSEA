APP_NAME=MSEA
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

BCRYPT_ROUNDS=4
CACHE_STORE=array
MAIL_MAILER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
FILESYSTEM_DISK=public

# Safe PostgreSQL testing database. Create this DB separately and never point it
# to the development/production MSEA database.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=msea_testing
DB_USERNAME=postgres
DB_PASSWORD=

MSEA_DIRECTOR_EMAIL=director@msea.test
MSEA_DIRECTOR_PASSWORD=director123
MSEA_DIRECTOR_NAME=Director
MSEA_DIRECTOR_LASTNAME=MSEA
